package admincomponents

import (
  "placeholder_project_tag/internal/data"
  "placeholder_project_tag/pkg/logging"
)

templ LogsContainer(logs []*logging.Log, metadata data.LogsMetadata) {
  <div id="logs-container">
    @PageMetadata(metadata.FilterMetadata)

    // @LogList(logs)
    @LogTable(logs)
  </div>
}